# =============================================================================
# CEPHO.AI - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control (it's in .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
# For local development: postgresql://postgres:password@localhost:5432/cepho
# For production: Use your hosted database URL (e.g., Render, Supabase, AWS RDS)
DATABASE_URL=postgresql://postgres:password@localhost:5432/cepho

# -----------------------------------------------------------------------------
# Authentication & Security
# -----------------------------------------------------------------------------
# JWT secret for token signing (REQUIRED)
# Generate with: openssl rand -base64 32
# IMPORTANT: Use a strong, unique secret in production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Google OAuth credentials (REQUIRED for Google login)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# OAuth server URL (for Manus OAuth integration)
# Production: https://oauth.manus.im
# Development: http://localhost:3000
OAUTH_SERVER_URL=https://oauth.manus.im

# Integration encryption key (REQUIRED for secure integration storage)
# Generate with: openssl rand -hex 32
# Used to encrypt third-party API keys and tokens
INTEGRATION_ENCRYPTION_KEY=your-integration-encryption-key-change-this

# -----------------------------------------------------------------------------
# AI & LLM Configuration
# -----------------------------------------------------------------------------
# Enable/disable AI features (true/false)
# Set to false to disable all AI functionality
AI_ENABLED=true

# Default LLM provider (openai, anthropic, gemini)
# Determines which AI model to use by default
DEFAULT_LLM_PROVIDER=openai

# Built-in Forge API (Manus LLM gateway)
# NOTE: API keys are managed on Render, not in .env for security
# These are placeholders for local development only
BUILT_IN_FORGE_API_KEY=your-forge-api-key
BUILT_IN_FORGE_API_URL=https://forge.manus.im/v1

# -----------------------------------------------------------------------------
# Third-Party Integrations
# -----------------------------------------------------------------------------
# NOTE: In production, API keys are stored on Render as environment variables
# These are for local development only

# Asana API key (for project management integration)
# Get from: https://app.asana.com/0/my-apps
ASANA_API_KEY=your-asana-api-key

# ElevenLabs API key (for text-to-speech)
# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# -----------------------------------------------------------------------------
# Payment Processing (Stripe)
# -----------------------------------------------------------------------------
# NOTE: In production, Stripe keys are stored on Render
# These are for local development/testing only

# Stripe secret key
# Get from: https://dashboard.stripe.com/apikeys
# Use test key (sk_test_...) for development
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Stripe webhook secret (for webhook signature verification)
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Node environment (development, production, test)
NODE_ENV=development

# Server port
# Default: 3000
# Production: Usually set by hosting provider (e.g., Render)
PORT=3000

# -----------------------------------------------------------------------------
# Optional: Additional Services
# -----------------------------------------------------------------------------
# The following are optional and only needed if you're using these services

# Redis URL (for caching and session storage) - RECOMMENDED FOR PERFORMANCE
# Format: redis://host:port
# Local: redis://localhost:6379
# Upstash (free tier): Get from https://upstash.com/
REDIS_URL=redis://localhost:6379
# OR use Upstash Redis REST URL
# UPSTASH_REDIS_URL=https://your-upstash-url.upstash.io

# AWS S3 (for file storage)
# Get from: https://console.aws.amazon.com/iam/
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=cepho-uploads

# Sentry DSN (for error tracking) - RECOMMENDED FOR PRODUCTION
# Get from: https://sentry.io/settings/projects/
# Sign up at https://sentry.io (free tier available)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# SendGrid API Key (for email notifications)
# Get from: https://app.sendgrid.com/settings/api_keys
# SENDGRID_API_KEY=your-sendgrid-api-key

# Twilio (for SMS/WhatsApp notifications)
# Get from: https://console.twilio.com/
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# Development Tools
# -----------------------------------------------------------------------------
# Logging level (error, warn, info, http, debug)
# Use 'debug' for development, 'info' for production
LOG_LEVEL=debug

# Verbose logging (true/false)
# Set to true for detailed logs during development
# VERBOSE_LOGGING=false

# Enable debug mode (true/false)
# Enables additional debugging features
# DEBUG_MODE=false

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
# Supabase project URL
# Get from: https://app.supabase.com/project/<your-project>/settings/api
SUPABASE_URL=https://your-project.supabase.co
# Supabase service role key (server-side only, NEVER expose to client)
SUPABASE_SERVICE_KEY=your-supabase-service-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Supabase JWT secret (for verifying tokens server-side)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# -----------------------------------------------------------------------------
# Admin Seed Account
# -----------------------------------------------------------------------------
# Used by the seed script to create the initial admin user
ADMIN_EMAIL=admin@cepho.ai
ADMIN_NAME=Admin
ADMIN_PASSWORD=change-this-strong-password
# Owner OpenID (Supabase user ID of the platform owner)
OWNER_OPEN_ID=your-supabase-user-id

# -----------------------------------------------------------------------------
# Session
# -----------------------------------------------------------------------------
SESSION_SECRET=your-session-secret-change-this

# -----------------------------------------------------------------------------
# Email Configuration (SMTP)
# -----------------------------------------------------------------------------
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
EMAIL_PRIMARY=hello@cepho.ai
EMAIL_BUSINESS=business@cepho.ai

# -----------------------------------------------------------------------------
# AI Integrations
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# Victoria voice ID (ElevenLabs)
ELEVENLABS_VICTORIA_VOICE_ID=your-victoria-voice-id
# Synthesia avatar (for video generation)
SYNTHESIA_API_KEY=your-synthesia-api-key
SYNTHESIA_VICTORIA_AVATAR_ID=your-victoria-avatar-id

# -----------------------------------------------------------------------------
# Productivity Integrations
# -----------------------------------------------------------------------------
NOTION_API_KEY=secret_your-notion-api-key
TODOIST_API_KEY=your-todoist-api-key
TRELLO_API_KEY=your-trello-api-key
TRELLO_API_SECRET=your-trello-api-secret
CALENDLY_API_KEY=your-calendly-api-key
ASANA_API=your-asana-api-key
ASANA_EMAIL=your-asana-email
GITHUB_API_KEY=your-github-api-key
GITHUB_EMAIL=your-github-email
GITHUB_TOKEN=your-github-token
GMAIL_EMAIL=your-gmail-email

# Zoom OAuth
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# -----------------------------------------------------------------------------
# Stripe Pricing IDs
# -----------------------------------------------------------------------------
STRIPE_PRO_PRICE_ID=price_your-stripe-pro-price-id

# -----------------------------------------------------------------------------
# Frontend (Vite) Variables
# -----------------------------------------------------------------------------
VITE_APP_ID=cepho-brain
VITE_APP_URL=http://localhost:3000
VITE_AUTH_BYPASS=false

# -----------------------------------------------------------------------------
# Development / Testing Flags
# -----------------------------------------------------------------------------
# Bypass authentication for local development (NEVER use in production)
AUTH_BYPASS=false
# Disable rate limiting for local development
DISABLE_RATE_LIMIT=false
# Base URL for E2E tests
TEST_BASE_URL=http://localhost:3000

# =============================================================================
# IMPORTANT NOTES
# =============================================================================
# 1. **Never commit .env to git** - It contains sensitive credentials
# 2. **Use different values for dev/prod** - Especially JWT_SECRET and API keys
# 3. **Render manages production secrets** - API keys are set on Render, not in .env
# 4. **Generate strong secrets** - Use openssl or a password generator
# 5. **Rotate keys regularly** - Change JWT_SECRET and encryption keys periodically
# 6. **Test locally first** - Verify all integrations work before deploying
#
# For more information, see README.md
# =============================================================================
